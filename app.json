{
  "expo": {
    "name": "DDH Electronics",
    "slug": "ddh-store",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo_brand.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo_splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ddh.store"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_brand.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.ddh.store"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
